# AumOS Vendor Intelligence — Environment Variables
# Copy to .env and fill in real values before running locally.

# ---------------------------------------------------------------------------
# Database (Neon / Vercel Postgres)
# ---------------------------------------------------------------------------
AUMOS_VENDOR_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aumos_vendor_intelligence
AUMOS_VENDOR_DATABASE_POOL_SIZE=10
AUMOS_VENDOR_DATABASE_MAX_OVERFLOW=20

# ---------------------------------------------------------------------------
# Kafka
# ---------------------------------------------------------------------------
AUMOS_VENDOR_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
AUMOS_VENDOR_KAFKA_CONSUMER_GROUP=aumos-vendor-intelligence

# ---------------------------------------------------------------------------
# Service identity
# ---------------------------------------------------------------------------
AUMOS_VENDOR_SERVICE_NAME=aumos-vendor-intelligence
AUMOS_VENDOR_ENVIRONMENT=development
AUMOS_VENDOR_LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Vendor evaluation scoring weights (must sum to 1.0)
# ---------------------------------------------------------------------------
AUMOS_VENDOR_SCORING_WEIGHT_API_COMPATIBILITY=0.25
AUMOS_VENDOR_SCORING_WEIGHT_DATA_PORTABILITY=0.25
AUMOS_VENDOR_SCORING_WEIGHT_SECURITY_POSTURE=0.20
AUMOS_VENDOR_SCORING_WEIGHT_PRICING_TRANSPARENCY=0.15
AUMOS_VENDOR_SCORING_WEIGHT_SUPPORT_QUALITY=0.15

# ---------------------------------------------------------------------------
# Lock-in risk thresholds
# ---------------------------------------------------------------------------
AUMOS_VENDOR_LOCK_IN_HIGH_RISK_THRESHOLD=0.70
AUMOS_VENDOR_LOCK_IN_MEDIUM_RISK_THRESHOLD=0.40

# ---------------------------------------------------------------------------
# Contract risk analysis
# ---------------------------------------------------------------------------
# AumOS policy: contracts capping liability at <= 1 month of fees are flagged
AUMOS_VENDOR_LIABILITY_CAP_WARNING_THRESHOLD=0.88
AUMOS_VENDOR_CONTRACT_ANALYSIS_LLM_MODEL=claude-opus-4-6
AUMOS_VENDOR_CONTRACT_ANALYSIS_MAX_TOKENS=4096

# ---------------------------------------------------------------------------
# Insurance gap detection
# ---------------------------------------------------------------------------
AUMOS_VENDOR_MINIMUM_COVERAGE_AMOUNT_USD=5000000

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
AUMOS_VENDOR_SENTRY_DSN=
AUMOS_VENDOR_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
